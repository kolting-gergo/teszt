# --- Vercel Neon (Postgres) ---
# A Neon connection string. Vercel: Storage → Neon → .env.local.
# Helyben: másold ezt a fájlt .env.local néven és töltsd ki.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Vercel Blob (fájltárolás) ---
# Vercel: Storage → Blob → "Read/Write Token".
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# --- Vercel AI Gateway ---
# Vercel: AI Gateway → API key. (Vercelen deploykor OIDC tokennel is mehet.)
AI_GATEWAY_API_KEY="vck_xxxxxxxxxxxx"
# Opcionális alapértelmezett modell (provider/model formában):
# AI_GATEWAY_MODEL="openai/gpt-4o-mini"
